# ─────────────────────────────────────────────────────────
# ResumeAI Backend Environment Variables
# Copy this file to .env and fill in your actual credentials
# ─────────────────────────────────────────────────────────

# Database (Used across all microservices)
DB_PASSWORD=Singh12345

# Message Broker (Used by Export and Notification services)
RABBITMQ_PASSWORD=guest

# Email SMTP (Used by Notification service)
MAIL_PASSWORD=your_gmail_app_password

# Authentication (Used by Auth service)
JWT_SECRET=your_super_secret_jwt_key_that_is_long_enough
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# AI APIs (Used by AI service)
GEMINI_API_KEY=your_gemini_api_key

# Job APIs (Used by Jobmatch service)
RAPIDAPI_LINKEDIN_KEY=your_rapidapi_linkedin_key
RAPIDAPI_NAUKRI_KEY=your_rapidapi_naukri_key

# Payments (Used by Payment service)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
